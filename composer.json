{
  "name": "hirasso/festival-perspectives-events",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Rasso Hilber",
      "email": "mail@rassohilber.com",
      "homepage": "https://rassohilber.com"
    }
  ],
  "require": {
    "php": ">=8.2",
    "hirasso/attr": "^4.4",
    "illuminate/collections": "^11 || ^12",
    "monolog/monolog": "^3.10",
    "oscarotero/env": "^2.1"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "Hirasso\\WP\\FPEvents\\": [
        "src"
      ]
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Hirasso\\WP\\FPEvents\\Tests\\": "tests"
    }
  },
  "scripts": {
    "format": "vendor/bin/pint",
    "analyse": "vendor/bin/phpstan analyse --memory-limit=2G"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "composer/installers": true,
      "pestphp/pest-plugin": true,
      "phpstan/extension-installer": true,
      "roots/wordpress-core-installer": true
    }
  },
  "extra": {
    "installer-paths": {
      "vendor/.wp/mu-plugins/{$name}/": [
        "type:wordpress-muplugin"
      ],
      "vendor/.wp/plugins/{$name}/": [
        "type:wordpress-plugin"
      ],
      "vendor/.wp/themes/{$name}/": [
        "type:wordpress-theme"
      ]
    },
    "wordpress-install-dir": "vendor/.wp/core"
  },
  "require-dev": {
    "filp/whoops": "^2.18",
    "laravel/pint": "^1.27",
    "pestphp/pest": "^1.23",
    "phpstan/extension-installer": "^1.4",
    "phpstan/phpstan": "^2.1",
    "roots/wordpress": "^6.9",
    "symfony/var-dumper": "^7.4",
    "szepeviktor/phpstan-wordpress": "^2.0",
    "vinkla/extended-acf": "^14.6",
    "wordpress-premium/advanced-custom-fields-pro": "^6.6",
    "wp-cli/wp-cli": "^2.12",
    "wp-phpunit/wp-phpunit": "^6.9",
    "wp-plugin/classic-editor": "^1.6",
    "wp-plugin/polylang": "^3.7",
    "wp-theme/twentytwentyfive": "^1.4",
    "yoast/wp-test-utils": "^1.2"
  },
  "repositories": [
    {
      "name": "wp-packages",
      "type": "composer",
      "url": "https://repo.wp-packages.org"
    }
  ]
}
