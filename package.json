{
  "name": "festival-perspectives-events",
  "version": "1.1.1",
  "private": true,
  "type": "module",
  "engineStrict": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prepare": "composer install && husky",
    "make-pot": "tools/make-pot.sh",
    "version": "pnpm changeset version",
    "env": "wp-env",
    "launch": "open $(wp-env status --json | jq -r '.urls.development')",
    "composer": "wp-env run cli --env-cwd=wp-content/plugins/festival-perspectives-events composer",
    "wp": "wp-env run cli wp",
    "test:unit": "pnpm run composer test",
    "test:unit:watch": "pnpm run composer test:watch",
    "test:e2e": "pnpm run wp plugin activate --all && pnpm exec playwright test --config ./tests/E2E/playwright.config.ts",
    "test:e2e:dev": "PLAYWRIGHT_ENV=dev pnpm run test:e2e --ui",
    "test:e2e:install": "pnpm exec playwright install --with-deps"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@wordpress/env": "^11.1.0",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "picocolors": "^1.1.1"
  }
}
